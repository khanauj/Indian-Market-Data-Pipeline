ENV=test
LOG_LEVEL=WARNING
TZ=Asia/Kolkata

STORAGE_BACKEND=sqlite
SQLITE_PATH=:memory:

API_HOST=127.0.0.1
API_PORT=8001
ADMIN_API_KEY=test-admin-key

# Tests use a throwaway local Postgres or sqlite-via-asyncpg shim.
# CI provisions a Postgres service container; locally, point at it.
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=test-key
SUPABASE_ANON_KEY=test-key
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/market_test
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=4

REDIS_URL=redis://localhost:6379/15
CACHE_ENABLED=false

HTTP_TIMEOUT_SECONDS=5
HTTP_MAX_RETRIES=1
HTTP_RATE_LIMIT_PER_SOURCE_MS=0
SCRAPER_CONCURRENCY=2

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_LOCALE=en-IN
PLAYWRIGHT_TIMEZONE=Asia/Kolkata
PLAYWRIGHT_VIEWPORT_WIDTH=1280
PLAYWRIGHT_VIEWPORT_HEIGHT=720

CIRCUIT_BREAKER_FAIL_THRESHOLD=2
CIRCUIT_BREAKER_RESET_SECONDS=5

SCHEDULER_ENABLED=false
SCREENER_BATCH_SIZE=2

PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9091
