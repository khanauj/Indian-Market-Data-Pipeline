# ─── App ────────────────────────────────────────────────────────────
ENV=development                       # development | staging | production
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
TZ=Asia/Kolkata

# ─── API server ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
ADMIN_API_KEY=change-me-in-prod       # required for POST /admin/* routes

# ─── Storage backend ────────────────────────────────────────────────
# sqlite   — local file, zero-setup (default). Good for dev + first ingest.
# supabase — Supabase Postgres via asyncpg + supabase-py
# both     — tee every write to both backends. Reads still come from Supabase.
STORAGE_BACKEND=sqlite
SQLITE_PATH=data/market.sqlite

# ─── Supabase (only needed if STORAGE_BACKEND=supabase or both) ─────
# https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...  # server-side only, never expose
SUPABASE_ANON_KEY=eyJhbGci...

# Pooled connection (Supavisor port 6543) — required for serverless / many connections
# Direct connection (port 5432) is fine for long-lived workers
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_DEFAULT_TTL=240                 # 4 minutes
CACHE_ENABLED=true

# ─── Scraper HTTP ───────────────────────────────────────────────────
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=4
HTTP_RATE_LIMIT_PER_SOURCE_MS=500     # min interval between requests per source
SCRAPER_CONCURRENCY=10                # asyncio.Semaphore for BSE bulk fetches

# Optional proxy (used by Screener / Moneycontrol on Cloudflare blocks)
PROXY_URL=
PROXY_ROTATE_ON_BLOCK=true

# ─── Playwright ─────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_LOCALE=en-IN
PLAYWRIGHT_TIMEZONE=Asia/Kolkata
PLAYWRIGHT_VIEWPORT_WIDTH=1920
PLAYWRIGHT_VIEWPORT_HEIGHT=1080

# ─── Circuit breaker ────────────────────────────────────────────────
CIRCUIT_BREAKER_FAIL_THRESHOLD=3
CIRCUIT_BREAKER_RESET_SECONDS=60

# ─── Scheduler ──────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCREENER_BATCH_SIZE=50                # max companies per Screener run

# ─── Observability ──────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
ALERT_WEBHOOK_URL=                    # optional Slack/Discord webhook for failures

# ─── Sentry (optional) ──────────────────────────────────────────────
SENTRY_DSN=
